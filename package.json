{
  "name": "axis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev --webpack -p 3002",
    "build": "node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "textures": "powershell -ExecutionPolicy Bypass -File scripts/fetch-space-textures.ps1",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "db:up": "docker compose up -d mongodb",
    "db:down": "docker compose down",
    "db:setup": "npm run db:up && npm run prisma:push && npm run prisma:generate",
    "postinstall": "prisma generate",
    "db:test": "node scripts/test-db.mjs",
    "db:seed": "node scripts/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@prisma/extension-accelerate": "3.0.1",
    "@react-three/drei": "^10.0.7",
    "@react-three/fiber": "^9.1.2",
    "@react-three/postprocessing": "^3.0.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.9.4",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "mongodb": "7.2.0",
    "next": "16.2.4",
    "nodemailer": "^8.0.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "three": "^0.175.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.175.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^6.19.0",
    "typescript": "^5"
  }
}
